# =============================================================================
# Aldi Cart — environment variables template
# =============================================================================
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#   # then fill in real values
#
# In Dokploy, set these in the service's "Environment" tab instead of
# committing a `.env` file. Secrets (DATABASE_URL, PROXY_URL) MUST NOT
# be committed to git — `.env*` is gitignored for that reason.
#
# Each var is annotated with:
#   - Required / Optional
#   - Where it's used (file:line, approximately)
#   - A safe example value (real credentials go in .env, NOT here)
# =============================================================================


# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# PostgreSQL connection URL. The app server uses this for every request.
# - Local dev:  postgresql://postgres:dev@localhost:5432/grocery-cart
# - Dokploy:    postgresql://postgres:USER@database-grocerycart-l0kdmu:5432/grocery-cart
#               (use the internal Dokploy hostname so traffic stays on the
#                private service network, not the public internet)
# - External:   postgresql://user:pass@db.example.com:5432/grocery-cart
#
# The app crashes with a clear error on the first request if this is unset.
# The schema (CREATE TABLE IF NOT EXISTS) is bootstrapped on the first query,
# so a fresh DB works out of the box.
DATABASE_URL=postgresql://user:password@host:5432/grocery-cart


# -----------------------------------------------------------------------------
# Optional — server
# -----------------------------------------------------------------------------

# Port the HTTP server listens on. Default 3000.
# Traefik/Dokploy forwards 80/443 to this port.
# HTTP_PORT=3000

# Port the HTTPS server listens on. Default 7778.
# Only used in dev/LAN mode for camera access on iOS Safari. In production
# behind Dokploy, Traefik terminates TLS and this port is unused.
# HTTPS_PORT=7778

# Bind address. Default 0.0.0.0 (all interfaces). Set to 127.0.0.1 for
# local-only dev.
# HOST=0.0.0.0

# Default Aldi service-point code. Affects which store's catalogue the
# sync scripts target. Default G452 (Perth Central).
# ALDI_SERVICE_POINT=G452


# -----------------------------------------------------------------------------
# Optional — Better Auth
# -----------------------------------------------------------------------------

# Secret used to sign Better Auth session cookies. Generate one with:
#   openssl rand -base64 32
# In production this MUST be set. Without it, every server restart
# invalidates every session and signing uses a random key (dev only).
# BETTER_AUTH_SECRET=

# Public URL of the app. Used by Better Auth to compute cookie domains
# and validate redirect targets. In Dokploy set this to the same
# hostname Traefik terminates TLS on (e.g. https://aldi.example.com).
# In dev with LAN HTTPS, use https://<lan-ip>:7778.
# BETTER_AUTH_URL=

# Bootstrap admin credentials. On the first cold start, if no user
# exists with ADMIN_EMAIL, one is created and promoted to the 'admin'
# role. After that, sign-ups via /signup are always 'user' role.
# Leave unset in environments where you want to provision admins
# manually (you'd then create one with the CLI or a direct DB insert).
# ADMIN_EMAIL=
# ADMIN_PASSWORD=


# -----------------------------------------------------------------------------
# Optional — sync scripts (host only; the app server does not read these)
# -----------------------------------------------------------------------------

# Webshare rotating proxy URL. Only used by `npm run sync:off` to fetch
# Open Food Facts products without hitting the silent-HTML ban page.
# Format: http://user:pass@p.webshare.io:80
# Leave unset to make sync scripts attempt direct connection (gets
# rate-limited fast for any non-trivial volume).
# PROXY_URL=

# Force the proxy off even if PROXY_URL is set. Useful for debugging
# direct connectivity from the dev machine.
# ALDI_PROXY=off
