{
  "name": "aldi-cart-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:css && next dev",
    "dev:https": "npm run build:css && tsx server.ts",
    "build": "npm run build:css && next build --webpack",
    "start": "npm run build:css && next start",
    "start:https": "npm run build:css && NODE_ENV=production tsx server.ts",
    "start:docker": "node dist/server.js",
    "build:css": "node scripts/tailwind-standalone.mjs src/app/globals.css src/app/globals.compiled.css",
    "lint": "eslint",
    "postinstall": "bash scripts/copy-wasm.sh",
    "sync:aldi": "tsx --env-file-if-exists=.env scripts/sync-aldi.ts",
    "sync:off": "tsx --env-file-if-exists=.env scripts/sync-off.ts",
    "match": "tsx --env-file-if-exists=.env scripts/match.ts",
    "sync:all": "npm run sync:aldi && npm run sync:off && npm run match",
    "test:e2e": "node test-e2e.mjs",
    "https:gen": "bash scripts/gen-https.sh"
  },
  "dependencies": {
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.22.0",
    "better-sqlite3": "^12.11.1",
    "bwip-js": "^4.11.1",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "undici": "^8.5.0",
    "web-wasm-barcode-reader": "^1.6.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
